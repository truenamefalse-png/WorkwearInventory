<Window x:Class="WorkwearInventory.IssueDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Наряд на выдачу" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="НАРЯД НА ВЫДАЧУ СПЕЦОДЕЖДЫ" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock x:Name="EmployeeText" FontWeight="SemiBold"/>
            <TextBlock x:Name="DateText"/>
            <TextBlock x:Name="PeriodText"/>
            <TextBlock x:Name="DueDateText" Foreground="#C0392B"/>
        </StackPanel>

        <ListBox Grid.Row="2" x:Name="ItemsList" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProductName}" Width="180"/>
                        <TextBlock Text="{Binding Size, StringFormat='Размер: {0}'}" Width="80"/>
                        <TextBlock Text="{Binding Quantity, StringFormat='x{0}'}" Width="50"/>
                        <TextBlock Text="{Binding WearPeriodDays, StringFormat='срок: {0} дн.'}" Width="100"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Дата окончания срока:" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock x:Name="DueDateText2" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Печать" Style="{StaticResource ModernButton}" Click="Print_Click" Width="90" FontSize="14" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Style="{StaticResource ModernButton}" Click="SaveToFile_Click" Width="90" FontSize="14" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>