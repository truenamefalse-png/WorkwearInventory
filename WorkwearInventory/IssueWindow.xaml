<Window x:Class="WorkwearInventory.IssueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выдача спецодежды" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource LightBrush}">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Оформление выдачи" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

            <TextBlock Text="ФИО сотрудника:"/>
            <TextBox x:Name="EmployeeNameBox" Style="{StaticResource ModernTextBox}" Margin="0,5,0,10"/>

            <TextBlock Text="Количество:"/>
            <TextBox x:Name="QuantityBox" Style="{StaticResource ModernTextBox}" Text="1" Margin="0,5,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Выдать" Style="{StaticResource ModernButton}" 
                        Background="#27AE60" Click="IssueButton_Click" Width="80"/>
                <Button Content="Отмена" Style="{StaticResource ModernButton}" 
                        Background="#95A5A6" Click="CancelButton_Click" Width="80" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>