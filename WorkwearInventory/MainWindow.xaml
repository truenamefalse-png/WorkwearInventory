<Window x:Class="WorkwearInventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Склад спецодежды" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource LightBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel Margin="10">
                <TextBlock Text="СПЕЦОДЕЖДА" Foreground="White" FontSize="18" FontWeight="Bold"
                           Margin="0,20,0,30" HorizontalAlignment="Center"/>
                <Button Content="Товары" Style="{StaticResource ModernButton}" 
                        Background="#34495E" Click="NavigateToProducts"/>
                <Button Content="Категории" Style="{StaticResource ModernButton}" 
                        Background="#34495E" Click="NavigateToCategories"/>
                <Button Content="Отчёты" Style="{StaticResource ModernButton}" 
                        Background="#34495E" Click="NavigateToReports"/>
                <Button x:Name="UsersButton" Content="Пользователи" Style="{StaticResource ModernButton}" 
                        Background="#34495E" Click="NavigateToUsers" Visibility="Collapsed"/>
                <Button Content="Выход" Style="{StaticResource ModernButton}" 
                        Background="#E74C3C" Click="Logout_Click" Margin="0,30,0,0"/>
                <TextBlock Text="Пользователь:" Foreground="#BDC3C7" Margin="0,20,0,0"/>
                <TextBlock x:Name="CurrentUserText" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>