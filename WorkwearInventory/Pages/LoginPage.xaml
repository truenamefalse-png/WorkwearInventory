<Page x:Class="WorkwearInventory.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource LightBrush}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" Padding="40" CornerRadius="10" Width="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Вход в систему" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Логин" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource ModernTextBox}"/>
                <TextBlock Text="Пароль" Margin="0,15,0,5"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource ModernPasswordBox}"/>
                <Button Content="Войти" Style="{StaticResource ModernButton}" 
                        Margin="0,20,0,10" Click="Login_Click"/>
                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink Click="GoToRegister_Click">Регистрация</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>