<Window x:Class="WorkwearInventory.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить товар" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource LightBrush}">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Название:"/>
            <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>

            <TextBlock Text="Описание:" Margin="0,10,0,0"/>
            <TextBox x:Name="DescriptionBox" Style="{StaticResource ModernTextBox}" Height="60" TextWrapping="Wrap"/>

            <TextBlock Text="Категория:" Margin="0,10,0,0"/>
            <ComboBox x:Name="CategoryCombo" Style="{StaticResource ModernComboBox}"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Цена:" Margin="0,10,0,0"/>
            <TextBox x:Name="PriceBox" Style="{StaticResource ModernTextBox}"/>

            <TextBlock Text="Количество:" Margin="0,10,0,0"/>
            <TextBox x:Name="StockBox" Style="{StaticResource ModernTextBox}"/>

            <TextBlock Text="Фото:" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="Выбрать..." Style="{StaticResource ModernButton}" Click="ChoosePhoto_Click"/>
                <TextBlock x:Name="PhotoNameText" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <Button Content="Сохранить" Style="{StaticResource ModernButton}" 
                    Width="100" Margin="0,20,0,0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>