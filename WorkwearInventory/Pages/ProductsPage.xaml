<Page x:Class="WorkwearInventory.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары" Background="{StaticResource LightBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель фильтрации и кнопки -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CategoryFilter" Width="150" Style="{StaticResource ModernComboBox}"
                          SelectionChanged="FilterChanged"/>
                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="150" Style="{StaticResource ModernTextBox}" 
                         TextChanged="FilterChanged"/>
                <Button Content="Добавить товар" Style="{StaticResource ModernButton}" 
                        Click="AddProduct_Click" Margin="20,0,0,0"/>
            </StackPanel>

            <!-- Таблица товаров -->
            <DataGrid x:Name="ProductsGrid" Grid.Row="1" Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Фото" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding PhotoPath, Converter={StaticResource ImageConverter}}" 
                                       Width="60" Height="60" Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="120"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="100"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2} руб}" Width="80"/>
                    <DataGridTemplateColumn Header="Остаток" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Stock}" 
                                           Foreground="{Binding Stock, Converter={StaticResource StockColorConverter}}"
                                           FontWeight="Bold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Действия" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Продать" Style="{StaticResource ModernButton}" 
                                            Background="#27AE60" FontSize="11" Padding="5,2"
                                            Click="SellProduct_Click" Tag="{Binding Id}"/>
                                    <Button Content="Изм." Style="{StaticResource ModernButton}" 
                                            Background="#F39C12" FontSize="11" Padding="5,2"
                                            Click="EditProduct_Click" Tag="{Binding Id}"/>
                                    <Button Content="Удал." Style="{StaticResource ModernButton}" 
                                            Background="#E74C3C" FontSize="11" Padding="5,2"
                                            Click="DeleteProduct_Click" Tag="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</Page>