<Page x:Class="WorkwearInventory.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource LightBrush}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" Padding="40" CornerRadius="10" Width="350">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Логин"/>
                <TextBox x:Name="RegUsernameBox" Style="{StaticResource ModernTextBox}"/>
                <TextBlock Text="Пароль" Margin="0,10,0,5"/>
                <PasswordBox x:Name="RegPasswordBox" Style="{StaticResource ModernPasswordBox}"/>
                <Button Content="Зарегистрироваться" Style="{StaticResource ModernButton}" 
                        Margin="0,20,0,10" Click="Register_Click"/>
                <TextBlock HorizontalAlignment="Center">
                    <Hyperlink Click="BackToLogin_Click">Вернуться ко входу</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>