<Page x:Class="WorkwearInventory.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пользователи" Background="{StaticResource LightBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <DataGrid x:Name="UsersGrid" Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="*"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" Style="{StaticResource ModernButton}" 
                                        Background="#E74C3C" FontSize="11" Padding="5,2"
                                        Click="DeleteUser_Click" Tag="{Binding Username}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </ScrollViewer>
</Page>