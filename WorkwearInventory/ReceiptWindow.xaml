<Window x:Class="WorkwearInventory.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чек" Height="350" Width="450" WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ЧЕК ПРОДАЖИ" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="ReceiptList" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProductName}" Width="150"/>
                        <TextBlock Text="{Binding Quantity}" Width="50"/>
                        <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="80"/>
                        <TextBlock Text="{Binding LineTotal, StringFormat={}{0:N2}}" FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Итого:" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock x:Name="TotalText" FontWeight="Bold" FontSize="16"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Печать" Style="{StaticResource ModernButton}" Click="Print_Click" Margin="0,0,10,0"/>
            <Button Content="Сохранить в файл" Style="{StaticResource ModernButton}" Click="SaveToFile_Click"/>
        </StackPanel>
    </Grid>
</Window>