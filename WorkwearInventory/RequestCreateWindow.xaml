<Window x:Class="WorkwearInventory.RequestCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка" Height="340" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource LightBrush}">
    <Grid Margin="15">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ФИО сотрудника:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmployeeNameBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Наименование:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="ProductNameCombo" Style="{StaticResource ModernComboBox}" IsEditable="True"
                          Text="Выберите или введите" Margin="0,0,0,12"/>

                <TextBlock Text="Размер:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="SizeBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Количество:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="QuantityBox" Style="{StaticResource ModernTextBox}" Text="1" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Создать заявку" Style="{StaticResource ModernButton}" Background="#27AE60"
                            Click="Submit_Click" Width="140" FontSize="14" Padding="10,8"/>
                    <Button Content="Отмена" Style="{StaticResource ModernButton}" Background="#95A5A6"
                            Click="Cancel_Click" Width="90" Margin="10,0,0,0" FontSize="14" Padding="10,8"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>